    {
      "id": "react-text",
      "type": "text",
      "x": 505,
      "y": 655,
      "width": 390,
      "height": 230,
      "text": "react-simple-voting/  (React + TypeScript)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  App.tsx  (root component)\n  ├── Header / Footer / Account\n  ├── Voter → CandidateCard\n  └── NetworkIndicator · ContractAddress\n\n  store.ts  (MobX observable)\n  ├── contractAddress (localStorage)\n  ├── web3 instance · networkId\n  └── actions: updateStore()\n\n  hooks/\n  ├── useWeb3.ts → init window.ethereum\n  ├── useContract.ts → new web3.eth.Contract\n  ├── useVote.ts → voteForCandidate() tx\n  ├── useCandidateCount / Name / Score\n  └── useAccounts · useNetId",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1864ab",
