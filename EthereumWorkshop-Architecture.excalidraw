    {
      "id": "nodewallet-text",
      "type": "text",
      "x": 95,
      "y": 1025,
      "width": 350,
      "height": 160,
      "text": "Nodejs/NodeWallet/  (Wallet Toolkit)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  index.js\n  ├── transferEther()  → raw TX signing\n  └── voteCandidate()  → contract call\n\n  generatePublicKeyAddress.js → keypair\n  ecdsaSign.js → ECDSA signatures\n  decodeTransaction.js → TX decoder\n  parallelTransactions.js → batch TXs\n  subscribeEvent.js → event listeners\n  subscribeERC20.js → token events",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
