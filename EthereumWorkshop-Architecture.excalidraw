    {
      "id": "vue-text",
      "type": "text",
      "x": 955,
      "y": 655,
      "width": 390,
      "height": 230,
      "text": "vue-simplevoting/  (Vue 2 + Vuex)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  App.vue  (root + router-view)\n  ├── NavBar.vue\n  └── Views: Home.vue · About.vue\n\n  store/  (Vuex)\n  ├── state: web3, networkId, coinbase,\n  │         balance, contract instance\n  ├── actions: updateWeb3, createWallet,\n  │           updateBalance, updateNetworkId\n  └── mutations: state updates\n\n  util/\n  ├── index.js → Web3 initialization\n  └── validateConnection.js\n\n  abi/voting.json  (contract ABI)\n  userData/persistance.js (localStorage)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1864ab",
